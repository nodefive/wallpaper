#!/bin/bash

# Base directory for wallpapers
BASE_DIR="$HOME/Pictures/Wall"

# Get current hour and minute
HOUR=$(date +%H)
MINUTE=$(date +%M)

# Convert to minutes since midnight for easier comparison
CURRENT_TIME=$((10#$HOUR * 60 + 10#$MINUTE))

# Define time ranges in minutes since midnight
DAWN_START=$((5 * 60))        # 5:00 AM
DAWN_END=$((6 * 60 + 30))     # 6:30 AM
MORNING_END=$((12 * 60))      # 12:00 PM
EVENING_END=$((17 * 60 + 30)) # 5:30 PM
DUSK_END=$((18 * 60 + 10))    # 6:10 PM

# Determine which folder to use based on time
if [ $CURRENT_TIME -ge $DAWN_START ] && [ $CURRENT_TIME -lt $DAWN_END ]; then
    FOLDER="DuskDawn"
elif [ $CURRENT_TIME -ge $DAWN_END ] && [ $CURRENT_TIME -lt $MORNING_END ]; then
    FOLDER="Morning"
elif [ $CURRENT_TIME -ge $MORNING_END ] && [ $CURRENT_TIME -lt $EVENING_END ]; then
    FOLDER="Afternoon"
elif [ $CURRENT_TIME -ge $EVENING_END ] && [ $CURRENT_TIME -lt $DUSK_END ]; then
    FOLDER="DuskDawn"
else
    # Night time: 6:10 PM to 5:00 AM
    FOLDER="Night"
fi

WALLPAPER_DIR="$BASE_DIR/$FOLDER"

# Check if directory exists
if [ ! -d "$WALLPAPER_DIR" ]; then
    echo "Error: Directory $WALLPAPER_DIR not found!"
    exit 1
fi

# Get all image files from the folder (jpg, jpeg, png)
mapfile -t IMAGES < <(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" \) 2>/dev/null)

# Check if any images were found
if [ ${#IMAGES[@]} -eq 0 ]; then
    echo "Error: No images found in $WALLPAPER_DIR"
    exit 1
fi

# Select a random image
RANDOM_IMAGE="${IMAGES[$RANDOM % ${#IMAGES[@]}]}"

# Set the wallpaper
gsettings set org.gnome.desktop.background picture-uri-dark "file://$RANDOM_IMAGE"

echo "Wallpaper changed to: $RANDOM_IMAGE (from $FOLDER folder) at $(date '+%Y-%m-%d %H:%M:%S')"